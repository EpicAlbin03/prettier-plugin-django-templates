{
  "name": "prettier-plugin-django",
  "version": "0.6.0",
  "description": "Prettier plugin for Django templates",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "format": "prettier . --write",
    "check": "bun run typecheck && bun run lint && bun run test",
    "prepublishOnly": "bun run build && bun run check"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "melody-types": "^1.7.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "@vitest/eslint-plugin": "^1.6.19",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
