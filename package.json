{
  "name": "prettier-plugin-django-templates",
  "version": "0.1.0",
  "description": "Django template plugin for Prettier",
  "main": "plugin.js",
  "files": [
    "plugin.js",
    "plugin.js.map",
    "browser.js",
    "index.d.ts"
  ],
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./plugin.js"
    },
    "./browser": "./browser.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rollup -c",
    "check": "tsc --noEmit",
    "check:watch": "tsc --noEmit --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "ava",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm test",
    "changeset:version": "changeset version && git add --all",
    "changeset:publish": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EpicAlbin03/prettier-plugin-django-templates.git"
  },
  "keywords": [
    "prettier",
    "django"
  ],
  "author": "Albin Carlsson <inquires@albincarlsson.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/EpicAlbin03/prettier-plugin-django-templates/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "homepage": "https://github.com/EpicAlbin03/prettier-plugin-django-templates#readme",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.31.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24",
    "ava": "3.15.0",
    "prettier": "^3.8.0",
    "rollup": "4.61.1",
    "ts-node": "^10.9.2",
    "tsimp": "^2.0.12",
    "tslib": "^2.8.1",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "peerDependencies": {
    "prettier": "^3.0.0"
  }
}
