{
  "name": "prettier-plugin-django-templates",
  "version": "0.1.2",
  "description": "Prettier plugin for formatting Django HTML templates",
  "keywords": [
    "django",
    "formatter",
    "html",
    "plugin",
    "prettier",
    "templates"
  ],
  "homepage": "https://github.com/EpicAlbin03/prettier-plugin-django-templates#readme",
  "bugs": {
    "url": "https://github.com/EpicAlbin03/prettier-plugin-django-templates/issues"
  },
  "license": "MIT",
  "author": "Albin Carlsson <inquires@albincarlsson.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EpicAlbin03/prettier-plugin-django-templates.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/plugin.js",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./browser": "./dist/browser.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "lint": "vp lint",
    "format": "vp fmt",
    "prepublishOnly": "vp run build",
    "prepare": "vp config",
    "changeset:version": "changeset version && git add --all",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "prettier": "^3.8.0",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
