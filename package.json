{
  "name": "prettier-plugin-django-templates",
  "version": "0.1.1",
  "description": "Prettier plugin for formatting Django HTML templates",
  "main": "plugin.js",
  "files": [
    "plugin.js",
    "plugin.js.map",
    "browser.mjs",
    "index.d.ts"
  ],
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./plugin.js"
    },
    "./browser": {
      "types": "./index.d.ts",
      "import": "./browser.mjs",
      "default": "./browser.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.mjs",
    "check": "tsc --noEmit",
    "check:watch": "tsc --noEmit --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "ava",
    "test:package": "node test/package-smoke.mjs",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm test",
    "changeset:version": "changeset version && git add --all",
    "changeset:publish": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EpicAlbin03/prettier-plugin-django-templates.git"
  },
  "keywords": [
    "prettier",
    "plugin",
    "django",
    "html",
    "templates",
    "formatter"
  ],
  "author": "Albin Carlsson <inquires@albincarlsson.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/EpicAlbin03/prettier-plugin-django-templates/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "homepage": "https://github.com/EpicAlbin03/prettier-plugin-django-templates#readme",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24",
    "ava": "3.15.0",
    "prettier": "^3.8.0",
    "rolldown": "^1.1.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.6.0",
  "peerDependencies": {
    "prettier": "^3.0.0"
  }
}
